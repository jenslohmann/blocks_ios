    "howToPlay.step1.body" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Træk en brik fra bakken nederst og placer den på brættet. Du kan ikke rotere brikkerne."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag a piece from the tray at the bottom and place it on the board. Pieces cannot be rotated."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser une pièce depuis le plateau en bas et placez-la sur la grille. Les pièces ne peuvent pas être pivotées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画面下のトレイからピースをドラッグしてボードに配置します。ピースは回転できません。"
          }
        }
      }
    },
    "howToPlay.step1.heading" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Træk brikkerne"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag the pieces"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser les pièces"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ピースをドラッグ"
          }
        }
      }
    },
    "howToPlay.step2.body" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når en hel række eller kolonne er fyldt, fjernes den automatisk og du scorer point."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When a full row or column is completed, it clears automatically and you score points."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand une ligne ou une colonne est complétée, elle se supprime automatiquement et vous marquez des points."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "行または列が全て埋まると自動的にクリアされ、得点が入ります。"
          }
        }
      }
    },
    "howToPlay.step2.heading" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fyld rækker og kolonner"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fill rows and columns"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remplissez les lignes et colonnes"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "行と列を埋める"
          }
        }
      }
    },
    "howToPlay.step3.body" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jo flere rækker og kolonner du rydder på én gang, jo flere point scorer du. Klarer du det i træk, ganges pointene med 1,5!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The more rows and columns you clear at once, the more points you score. Do it consecutively and your score is multiplied by 1.5!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plus vous effacez de lignes en une fois, plus vous marquez de points. Faites-le consécutivement et votre score est multiplié par 1,5 !"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一度に多くの行・列をクリアするほど高得点。連続でクリアすると得点が1.5倍になります！"
          }
        }
      }
    },
    "howToPlay.step3.heading" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ryd flere ad gangen for bonus"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear multiple lines for a bonus"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effacez plusieurs lignes pour un bonus"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "複数同時クリアでボーナス"
          }
        }
      }
    },
    "howToPlay.step4.body" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har altid 3 brikker i bakken. Når alle 3 er placeret, får du 3 nye."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You always have 3 pieces in the tray. Once all 3 are placed, you get 3 new ones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez toujours 3 pièces dans le plateau. Une fois les 3 placées, vous en recevez 3 nouvelles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "トレイには常に3つのピースがあります。3つ全て配置すると新しい3つが登場します。"
          }
        }
      }
    },
    "howToPlay.step4.heading" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tre nye brikker ad gangen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Three new pieces at a time"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois nouvelles pièces à la fois"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3つのピースが一度に登場"
          }
        }
      }
    },
    "howToPlay.step5.body" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen af de 3 brikker kan placeres lovligt på brættet. Hold brættet så åbent som muligt!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "None of the 3 current pieces can be legally placed on the board. Keep the board as open as possible!"
          }
